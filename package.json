{
  "name": "openborder-medusa-demo",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@10.33.2",
  "engines": {
    "node": ">=20"
  },
  "description": "Standalone Open Border checkout preview and Medusa provider adapter harness.",
  "scripts": {
    "build:hosted-preview": "tsx scripts/build-static-preview.ts",
    "check": "pnpm public-safety && pnpm typecheck && pnpm build:hosted-preview",
    "public-safety": "node scripts/public-safety-check.mjs",
    "start": "tsx server.ts",
    "typecheck": "tsc --noEmit -p tsconfig.json"
  },
  "dependencies": {
    "@open-border/js": "0.3.0",
    "@open-border/medusa-payment-openborder": "0.3.0",
    "@open-border/node": "0.3.0",
    "dotenv": "^17.4.2",
    "express": "^4.21.2"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/node": "^22.10.5",
    "tsx": "^4.22.4",
    "typescript": "^5.9.3"
  }
}
