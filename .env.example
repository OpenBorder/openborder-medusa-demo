PORT=8000
DEMO_MODE=preview

# Leave the values above unchanged for the safe, keyless preview.
#
# To use the optional connected Test mode:
# 1. Copy this file to .env: cp .env.example .env
# 2. In .env, change DEMO_MODE=preview to DEMO_MODE=api.
# 3. In .env, uncomment the two lines below and paste the matching Test keys.
#
# Test keys automatically select the Test API. Do not add OPENBORDER_API_URL unless
# the Open Border team specifically asks you to override the default.
# The local server rejects live keys.
#
# Never put real keys in .env.example. Keep them only in the ignored .env file.
# OPENBORDER_API_KEY=<paste your Test secret key here>
# OPENBORDER_PUBLISHABLE_KEY=<paste the matching Test publishable key here>
